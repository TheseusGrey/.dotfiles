#!/usr/bin/env bash
# float-browser — Launch a chromeless floating browser window (PWA-style)
# Usage: float-browser <url>
# Example: float-browser https://chat.openai.com
#          float-browser https://music.youtube.com
#          float-browser file:///tmp/dashboard.html

set -euo pipefail

WIDTH=1280
HEIGHT=720
CLASS="float-browser"
PROFILE_DIR="${XDG_RUNTIME_DIR:-/tmp}/float-browser-profile"

if [[ $# -eq 0 ]]; then
    echo "Usage: float-browser <url>" >&2
    exit 1
fi

URL="$1"

# Ensure the temporary profile directory exists
mkdir -p "$PROFILE_DIR"

# Prefer Zen browser, fall back to Chromium variants.
# Uses a separate profile (--no-remote + --profile) to prevent opening as a tab
# in an existing window. Kiosk mode removes all chrome.
if command -v zen-browser &>/dev/null; then
    exec zen-browser \
        --no-remote \
        --profile "$PROFILE_DIR" \
        --kiosk "$URL" \
        --class "$CLASS"
elif command -v chromium &>/dev/null; then
    exec chromium \
        --app="$URL" \
        --user-data-dir="$PROFILE_DIR" \
        --window-size="${WIDTH},${HEIGHT}" \
        --class="$CLASS"
elif command -v chromium-browser &>/dev/null; then
    exec chromium-browser \
        --app="$URL" \
        --user-data-dir="$PROFILE_DIR" \
        --window-size="${WIDTH},${HEIGHT}" \
        --class="$CLASS"
elif command -v google-chrome &>/dev/null; then
    exec google-chrome \
        --app="$URL" \
        --user-data-dir="$PROFILE_DIR" \
        --window-size="${WIDTH},${HEIGHT}" \
        --class="$CLASS"
else
    echo "Error: No supported browser found (zen-browser, chromium, google-chrome)" >&2
    exit 1
fi
