#!/usr/bin/env bash
# float-term — Launch a floating kitty terminal centered at 720p
# Usage: float-term <command> [args...]
# Example: float-term htop
#          float-term nvim /tmp/notes.md
#          float-term bash -c "curl wttr.in && read"

set -euo pipefail

WIDTH=1280
HEIGHT=720
CLASS="float-term"

if [[ $# -eq 0 ]]; then
    echo "Usage: float-term <command> [args...]" >&2
    exit 1
fi

# Uses --class to set the Wayland app_id for reliable Hyprland matching.
# Window rule in hypr/windowrules.lua matches on class "float-term".
exec kitty \
    --class "$CLASS" \
    --title "$CLASS" \
    --override initial_window_width="${WIDTH}" \
    --override initial_window_height="${HEIGHT}" \
    --override remember_window_size=no \
    --override confirm_os_window_close=0 \
    "$@"
